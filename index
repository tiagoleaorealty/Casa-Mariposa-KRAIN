<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Villa Mariposa — Marketing Plan & CMA · KRAIN</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Manrope:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --ivory:#FBF6EE;
    --surface:#FFFFFF;
    --teal-deep:#0B3838;
    --teal:#114E50;
    --teal-bright:#1E817A;
    --fill:#EAF0EC;
    --fill-2:#F3F0E7;
    --coral:#DC7050;
    --coral-soft:#EBC4B2;
    --brass:#C39A50;
    --ink:#143130;
    --muted:#5F7372;
    --line:#E6DECF;
    --line-strong:#D4CBB8;

    --display:"Cormorant Garamond",Georgia,serif;
    --sans:"Manrope",system-ui,-apple-system,sans-serif;
    --mono:"DM Mono",ui-monospace,monospace;

    --maxw:1180px;
    --gutter:clamp(20px,5vw,72px);

    /* swap this URL for one of Tiago's hero captures before publishing */
    --hero-img:url("https://api.cotality.com/trestle/Media/Property/PHOTO-jpeg/1154874405/1/MzM2Ny8yMTY3LzE3/MTcvMTUyMTYvMTc4MTY1OTIxNA/zwmNFkagWzgqJRHxofWISHh3zsru64VjwAs_ZWl_L14");
  }

  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
  body{
    font-family:var(--sans);
    background:var(--ivory);
    color:var(--ink);
    line-height:1.62;
    font-size:17px;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  ::selection{background:var(--coral);color:#fff}
  a{color:inherit;text-decoration:none}
  img{max-width:100%;display:block}

  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 var(--gutter)}

  /* ---------- type ---------- */
  .eyebrow{
    font-family:var(--mono);
    font-size:12px;
    letter-spacing:.2em;
    text-transform:uppercase;
    color:var(--teal-bright);
    font-weight:500;
  }
  h1,h2,h3{font-family:var(--display);font-weight:600;line-height:1.03;letter-spacing:0;color:var(--teal-deep)}
  h2{font-size:clamp(34px,5.4vw,62px)}
  h3{font-size:clamp(21px,2.5vw,28px);line-height:1.12}
  .lead{font-size:clamp(18px,2.1vw,22px);color:var(--muted);line-height:1.55;font-weight:400}
  em{font-style:italic;color:var(--coral)}

  /* ---------- section frame ---------- */
  .section{padding:clamp(74px,11vw,140px) 0;position:relative}
  .section-head{max-width:760px;margin-bottom:clamp(40px,6vw,72px)}
  .section-head .eyebrow{display:block;margin-bottom:18px}
  .section-head h2{margin-bottom:22px}
  .divider{height:1px;background:var(--line);max-width:var(--maxw);margin:0 auto}

  /* ---------- butterfly signature ---------- */
  .mariposa{position:absolute;pointer-events:none;z-index:0;fill:none;stroke:var(--teal-bright);stroke-width:1;opacity:.13;stroke-linecap:round}
  .mariposa.coral{stroke:var(--coral)}

  /* ---------- top bar ---------- */
  .topbar{
    position:relative;z-index:3;
    border-bottom:1px solid var(--line);
    background:rgba(251,246,238,.86);
    backdrop-filter:saturate(140%) blur(6px);
  }
  .topbar .wrap{display:flex;justify-content:space-between;align-items:center;gap:16px;padding-top:16px;padding-bottom:16px;flex-wrap:wrap}
  .brand{font-family:var(--display);font-size:23px;font-weight:700;letter-spacing:.16em;color:var(--teal-deep)}
  .brand span{color:var(--coral)}
  .topbar .meta{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}

  /* ---------- hero ---------- */
  .hero{
    position:relative;min-height:92vh;display:flex;align-items:flex-end;
    padding:clamp(40px,8vw,90px) 0 clamp(46px,6vw,74px);
    background:
      linear-gradient(180deg,rgba(8,40,40,.30) 0%,rgba(8,40,40,.05) 26%,rgba(8,40,40,.55) 68%,rgba(7,34,34,.9) 100%),
      linear-gradient(96deg,rgba(8,40,40,.6) 0%,rgba(8,40,40,.12) 50%,rgba(8,40,40,0) 76%),
      var(--hero-img),
      linear-gradient(150deg,#114E50 0%,#0B3838 60%,#0a2c2c 100%);
    background-size:cover,cover,cover,cover;
    background-position:center,center,center 30%,center;
    overflow:hidden;
  }
  .hero .wrap{position:relative;z-index:2;width:100%}
  .hero .mariposa{top:7%;right:4%;width:min(340px,42vw);stroke:#fff;opacity:.15;stroke-width:.9}
  .hero .eyebrow{color:var(--brass);text-shadow:0 1px 16px rgba(4,22,22,.6)}
  .hero h1{
    font-size:clamp(52px,11vw,140px);
    line-height:.92;
    margin:20px 0 0;
    font-weight:600;
    color:#fff;
    text-shadow:0 2px 34px rgba(4,22,22,.5);
  }
  .hero h1 em{color:var(--brass)}
  .hero .place{margin-top:22px;font-size:clamp(17px,2.2vw,21px);color:#E8E0D2;max-width:620px;text-shadow:0 1px 18px rgba(4,22,22,.55)}
  .hero .place b{color:#fff;font-weight:600}
  .hero-foot{
    margin-top:clamp(40px,6vw,64px);
    display:flex;justify-content:space-between;align-items:flex-end;gap:32px;flex-wrap:wrap;
    padding-top:26px;border-top:1px solid rgba(255,255,255,.24);
  }
  .facts{display:flex;flex-wrap:wrap;gap:clamp(22px,4vw,52px)}
  .fact .n{font-family:var(--display);font-size:clamp(26px,3.6vw,42px);color:#fff;font-weight:600;line-height:1}
  .fact .l{font-family:var(--mono);font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:#C2D3CF;margin-top:9px}
  .agents-tag{text-align:right}
  .agents-tag .by{font-family:var(--mono);font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:#C2D3CF;margin-bottom:8px}
  .agents-tag .names{font-family:var(--display);font-size:clamp(20px,2.4vw,27px);color:#fff;font-weight:600}
  .agents-tag .names i{font-style:normal;color:var(--brass);padding:0 7px}
  .scroll-cue{margin-top:clamp(30px,5vw,46px);display:inline-flex;align-items:center;gap:10px;font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#D5E2DE}
  .scroll-cue .line{width:42px;height:1px;background:var(--brass);position:relative;overflow:hidden}
  .scroll-cue .line::after{content:"";position:absolute;inset:0;left:-100%;background:#fff;animation:slide 2.4s ease-in-out infinite}
  @keyframes slide{0%{left:-100%}55%{left:100%}100%{left:100%}}

  /* ---------- opportunity ---------- */
  .opp h2{max-width:14ch}
  .opp .lead{max-width:62ch;margin-top:24px}
  .opp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-top:clamp(46px,6vw,72px);border-radius:16px;overflow:hidden}
  .opp-cell{background:var(--surface);padding:clamp(26px,3vw,40px)}
  .opp-cell .k{font-family:var(--mono);font-size:11px;letter-spacing:.13em;text-transform:uppercase;color:var(--coral);margin-bottom:14px}
  .opp-cell h3{margin-bottom:10px}
  .opp-cell p{font-size:15.5px;color:var(--muted)}

  /* ---------- KRAIN dark band ---------- */
  .krain{background:var(--teal-deep);color:#E8F0EC;position:relative;overflow:hidden}
  .krain .eyebrow{color:var(--brass)}
  .krain h2{color:#fff;max-width:17ch}
  .krain .lead{color:#9FBAB4}
  .krain .wrap{position:relative;z-index:2}
  .krain .mariposa{bottom:-4%;left:-3%;width:min(420px,46vw);stroke:#fff;opacity:.07}
  .stat-grid{
    display:grid;grid-template-columns:repeat(4,1fr);
    gap:1px;background:rgba(255,255,255,.1);
    border:1px solid rgba(255,255,255,.1);
    margin-top:clamp(44px,6vw,64px);border-radius:16px;overflow:hidden;
  }
  .stat{background:var(--teal-deep);padding:clamp(22px,2.6vw,32px) clamp(20px,2.4vw,28px)}
  .stat .n{font-family:var(--display);font-size:clamp(32px,4vw,50px);color:#fff;font-weight:600;line-height:1}
  .stat .n b{color:var(--brass);font-weight:600}
  .stat .l{font-family:var(--sans);font-size:13px;color:#93B0AA;margin-top:11px;line-height:1.4}
  .badges{margin-top:34px;display:flex;flex-wrap:wrap;gap:10px}
  .badge{font-family:var(--mono);font-size:11px;letter-spacing:.05em;color:#D5E2DE;border:1px solid rgba(255,255,255,.18);padding:9px 14px;border-radius:100px}

  /* ---------- why us ---------- */
  .why-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(18px,2.4vw,26px)}
  .why-card{background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:clamp(28px,3.2vw,42px);transition:transform .4s cubic-bezier(.2,.7,.3,1),border-color .4s,box-shadow .4s}
  .why-card:hover{transform:translateY(-4px);border-color:var(--coral-soft);box-shadow:0 24px 54px -30px rgba(11,56,56,.42)}
  .why-card .ic{width:46px;height:46px;border-radius:12px;background:var(--fill-2);display:flex;align-items:center;justify-content:center;margin-bottom:22px;color:var(--coral)}
  .why-card .ic svg{width:23px;height:23px}
  .why-card h3{margin-bottom:12px}
  .why-card p{font-size:15.5px;color:var(--muted)}
  .why-card.feature{background:linear-gradient(155deg,#114E50,#0B3838);border-color:transparent;color:#E8F0EC}
  .why-card.feature h3{color:#fff}
  .why-card.feature p{color:#A9C4BE}
  .why-card.feature .ic{background:rgba(255,255,255,.08);color:var(--brass)}
  .why-card.feature .micro{font-family:var(--mono);font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:var(--brass);margin-bottom:16px}

  /* ---------- plan ---------- */
  .plan-list{margin-top:clamp(30px,4vw,48px);border-top:1px solid var(--line)}
  .plan-item{display:grid;grid-template-columns:auto 1fr;gap:clamp(20px,4vw,56px);padding:clamp(34px,4.4vw,56px) 0;border-bottom:1px solid var(--line);align-items:start}
  .plan-num{font-family:var(--display);font-size:clamp(30px,4.4vw,52px);color:var(--coral);font-weight:600;line-height:1;min-width:1.5em}
  .plan-body .k{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
  .plan-body h3{font-size:clamp(22px,2.8vw,32px);margin-bottom:14px;max-width:26ch}
  .plan-body p{color:var(--muted);max-width:64ch;font-size:16px}
  .tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:22px}
  .tag{font-family:var(--mono);font-size:11px;letter-spacing:.03em;color:var(--teal);background:var(--fill);padding:7px 13px;border-radius:100px}

  /* ---------- syndication ---------- */
  .synd-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:16px;overflow:hidden;margin-top:clamp(40px,5vw,60px)}
  .synd{background:var(--surface);padding:clamp(24px,3vw,34px);transition:background .35s}
  .synd:hover{background:var(--fill-2)}
  .synd .tagline{font-family:var(--mono);font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--coral);margin-bottom:12px}
  .synd h3{font-size:19px;margin-bottom:8px}
  .synd p{font-size:14px;color:var(--muted)}

  /* ---------- team ---------- */
  .team .section-head{text-align:center;margin-left:auto;margin-right:auto}
  .team .section-head .eyebrow{display:block;margin-bottom:16px}
  .team-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(18px,2.5vw,28px);margin-top:clamp(20px,3vw,40px)}
  .agent{background:var(--surface);border:1px solid var(--line);border-radius:20px;overflow:hidden;display:flex;flex-direction:column}
  .agent .ph{aspect-ratio:1/1;overflow:hidden;border-bottom:1px solid var(--line);background:var(--fill)}
  .agent .ph img{width:100%;height:100%;object-fit:cover;object-position:top center}
  .agent .body{padding:clamp(24px,3vw,34px);flex:1;display:flex;flex-direction:column}
  .agent .role{font-family:var(--mono);font-size:11px;letter-spacing:.13em;text-transform:uppercase;color:var(--coral);margin-bottom:10px}
  .agent h3{font-size:30px;margin-bottom:14px}
  .agent p{font-size:15px;color:var(--muted)}
  .agent .chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:auto;padding-top:22px}
  .agent .chip{font-family:var(--mono);font-size:11px;letter-spacing:.02em;color:var(--teal);background:var(--fill);padding:7px 12px;border-radius:100px}
  .partner-note{margin-top:clamp(30px,4vw,46px);text-align:center;max-width:62ch;margin-left:auto;margin-right:auto}
  .partner-note p{font-family:var(--display);font-size:clamp(20px,2.6vw,28px);color:var(--teal-deep);line-height:1.3}

  /* ---------- CMA ---------- */
  .cma{background:var(--fill-2);position:relative;overflow:hidden}
  .cma .mariposa{top:6%;right:-4%;width:min(380px,44vw)}
  .cma-wrap{overflow-x:auto;margin-top:clamp(34px,5vw,52px);border:1px solid var(--line);border-radius:16px}
  table.cma-t{width:100%;border-collapse:collapse;min-width:680px;background:var(--surface)}
  table.cma-t th,table.cma-t td{text-align:left;padding:15px 18px;border-bottom:1px solid var(--line)}
  table.cma-t thead th{font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:500;background:var(--fill-2)}
  table.cma-t td{font-size:15px;color:var(--ink)}
  table.cma-t .name{font-weight:600;color:var(--teal-deep)}
  table.cma-t .loc{color:var(--muted);font-size:13px}
  table.cma-t td.num,table.cma-t th.num{text-align:right;font-family:var(--mono);font-size:13.5px;white-space:nowrap}
  table.cma-t tbody tr:last-child td{border-bottom:none}
  table.cma-t tr.subject td{background:#F4EBE4;font-weight:600}
  table.cma-t tr.subject .name{color:var(--coral)}
  table.cma-t tr.land td{color:var(--muted)}
  .subject-pill{display:inline-block;font-family:var(--mono);font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:#fff;background:var(--coral);padding:2px 8px;border-radius:100px;margin-left:8px;vertical-align:middle}
  .cma-note{font-size:13.5px;color:var(--muted);margin-top:14px;max-width:80ch}

  .sold-head{margin-top:clamp(46px,6vw,72px);display:block}
  .sold-head .eyebrow{display:block;margin-bottom:14px}
  .sold-head h3{font-size:clamp(22px,3vw,34px);max-width:22ch}
  .sold-row{display:flex;flex-wrap:wrap;gap:14px;margin-top:clamp(26px,3.5vw,40px)}
  .sold-card{flex:1;min-width:230px;background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:24px 24px 22px}
  .sold-card .tagline{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--brass);margin-bottom:12px}
  .sold-card .price{font-family:var(--display);font-size:38px;color:var(--teal-deep);line-height:1;font-weight:600}
  .sold-card .ask{font-family:var(--mono);font-size:12px;color:var(--muted);margin-top:8px}
  .sold-card .ask s{color:var(--coral);text-decoration-thickness:1px}
  .sold-card .desc{font-size:13.5px;color:var(--muted);margin-top:12px;border-top:1px solid var(--line);padding-top:12px}

  .reco{background:var(--teal-deep);color:#E8F0EC;border-radius:22px;padding:clamp(34px,5vw,58px);margin-top:clamp(40px,5vw,60px);position:relative;overflow:hidden}
  .reco .mariposa{bottom:-10%;right:-3%;width:min(330px,38vw);stroke:#fff;opacity:.06}
  .reco-inner{position:relative;z-index:2;display:grid;grid-template-columns:1.05fr 1fr;gap:clamp(28px,4vw,54px);align-items:center}
  .reco .eyebrow{color:var(--brass);display:block;margin-bottom:16px}
  .reco .range{font-family:var(--display);font-size:clamp(36px,5.6vw,64px);color:#fff;line-height:1.02;font-weight:600}
  .reco .vs{display:block;font-family:var(--mono);font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#9FBAB4;margin-top:18px;font-weight:400}
  .reco .vs b{color:var(--coral);font-weight:500}
  .reco .target{display:block;font-family:var(--mono);font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#9FBAB4;margin-top:8px}
  .reco .target b{color:#fff;font-weight:500}
  .reco ul{list-style:none;display:flex;flex-direction:column;gap:14px}
  .reco li{position:relative;padding-left:24px;color:#C5D8D3;font-size:15px;line-height:1.5}
  .reco li::before{content:"";position:absolute;left:0;top:8px;width:8px;height:8px;border-radius:2px;background:var(--brass)}
  .reco li b{color:#fff;font-weight:600}

  /* ---------- close ---------- */
  .close{background:var(--teal);color:#E8F0EC;position:relative;overflow:hidden;text-align:center}
  .close .mariposa{top:50%;left:50%;transform:translate(-50%,-50%);width:min(620px,82vw);stroke:#fff;opacity:.08}
  .close .wrap{position:relative;z-index:2;max-width:900px}
  .close .eyebrow{color:var(--brass);display:block;margin-bottom:22px}
  .close h2{color:#fff;font-size:clamp(36px,6vw,72px);margin-bottom:24px}
  .close h2 em{color:var(--brass)}
  .close p{color:#A9C4BE;font-size:clamp(17px,2vw,20px);max-width:60ch;margin:0 auto 40px}
  .cta-row{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
  .btn{font-family:var(--sans);font-weight:600;font-size:15px;padding:16px 30px;border-radius:100px;display:inline-flex;align-items:center;gap:10px;transition:transform .3s,background .3s}
  .btn-primary{background:var(--brass);color:#2a2207}
  .btn-primary:hover{transform:translateY(-3px);background:#d4ab63}
  .btn-ghost{border:1px solid rgba(255,255,255,.28);color:#E8F0EC}
  .btn-ghost:hover{transform:translateY(-3px);background:rgba(255,255,255,.08)}

  /* ---------- agents footer ---------- */
  .agents{padding-top:clamp(50px,7vw,86px);padding-bottom:clamp(40px,6vw,70px);background:var(--ivory)}
  .agents-head{text-align:center;margin-bottom:clamp(30px,4vw,46px)}
  .agents-head .eyebrow{display:block;margin-bottom:14px}
  .agents-head h2{font-size:clamp(26px,3.4vw,42px)}
  .agent-row{display:flex;justify-content:center;gap:clamp(34px,7vw,96px);flex-wrap:wrap}
  .agent-card{text-align:center}
  .agent-card img{width:clamp(150px,18vw,186px);height:clamp(150px,18vw,186px);object-fit:cover;object-position:top center;border-radius:26px;border:1px solid var(--line)}
  .agent-card .nm{font-family:var(--display);font-size:clamp(22px,2.4vw,27px);color:var(--teal-deep);margin-top:18px;font-weight:600}
  .agent-card .rl{font-family:var(--mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:8px}

  footer{background:var(--teal-deep);color:#93B0AA;padding:40px 0;text-align:center}
  footer .brand{color:#fff;margin-bottom:8px;font-size:20px}
  footer p{font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase}

  /* ---------- reveal ---------- */
  .reveal{opacity:0;transform:translateY(26px);transition:opacity .8s cubic-bezier(.2,.7,.3,1),transform .8s cubic-bezier(.2,.7,.3,1)}
  .reveal.in{opacity:1;transform:none}
  .reveal[data-d="1"]{transition-delay:.08s}
  .reveal[data-d="2"]{transition-delay:.16s}
  .reveal[data-d="3"]{transition-delay:.24s}

  a:focus-visible,.btn:focus-visible{outline:3px solid var(--brass);outline-offset:3px;border-radius:6px}

  @media(max-width:900px){
    .opp-grid,.synd-grid{grid-template-columns:1fr 1fr}
    .opp-cell:last-child,.synd:last-child{grid-column:1 / -1}
    .stat-grid{grid-template-columns:repeat(2,1fr)}
    .why-grid,.team-grid{grid-template-columns:1fr}
    .reco-inner{grid-template-columns:1fr;gap:30px}
  }
  @media(max-width:620px){
    body{font-size:16px}
    .opp-grid,.synd-grid{grid-template-columns:1fr}
    .hero-foot{flex-direction:column;align-items:flex-start}
    .agents-tag{text-align:left}
    .plan-item{grid-template-columns:1fr;gap:8px}
  }
  @media(prefers-reduced-motion:reduce){
    .scroll-cue .line::after{animation:none}
  }
</style>
